{
  "name": "snapline-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Snapline monorepo — keep AI-generated UI on-system",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter \"@usesnapline/*\" build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench:static": "pnpm --filter agent-ui-drift-bench bench:static",
    "bench:graph": "pnpm --filter agent-ui-drift-bench bench:graph",
    "docs:check": "node scripts/check-docs.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
