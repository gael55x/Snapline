{
  "name": "agent-ui-drift-bench",
  "version": "0.0.0",
  "private": true,
  "description": "Benchmark: does Snapline reduce AI-generated UI drift vs raw agents, instructions, shadcn MCP, Tailwind ESLint, Buoy, and driftguard?",
  "type": "module",
  "scripts": {
    "bench:static": "tsx runners/run-static.ts",
    "bench:agent": "tsx runners/run-agent.ts",
    "bench:report": "tsx runners/generate-report.ts",
    "bench:graph": "tsx runners/generate-graphs.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@usesnapline/contracts": "workspace:*",
    "@usesnapline/core": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
